{
  "info": {
    "name": "OceanView Resort API",
    "description": "Basic user-side endpoints with example bodies",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","auth","login"]
        },
        "body": { "mode": "raw", "raw": "{\"email\":\"admin@oceanview.com\",\"password\":\"admin123\"}" }
      }
    },
    {
      "name": "Rooms - list",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/rooms",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","rooms"]
        }
      }
    },
    {
      "name": "Check availability",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "http://localhost:8080/api/bookings/check-availability", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api","bookings","check-availability"] },
        "body": { "mode": "raw", "raw": "{\"checkIn\":\"2026-04-10\",\"checkOut\":\"2026-04-15\",\"roomType\":\"Suite\"}" }
      }
    },
    {
      "name": "Create booking",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": { "raw": "http://localhost:8080/api/bookings", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api","bookings"] },
        "body": { "mode": "raw", "raw": "{\"roomId\":\"<ROOM_ID>\",\"userEmail\":\"guest@example.com\",\"checkIn\":\"2026-04-10\",\"checkOut\":\"2026-04-15\",\"guests\":2}" }
      }
    },
    {
      "name": "Packages - list",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:8080/api/packages", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api","packages"] }
      }
    },
    {
      "name": "Food items - list",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:8080/api/food/items", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api","food","items"] }
      }
    }
  ]
}